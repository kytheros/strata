# Node / Playwright
node_modules/
test-results/
playwright-report/
playwright/.cache/

# Local cookie / secret cache (test harness reads these — never commit)
.work/
*.session-cookie.txt

# Operator-only env file consumed by the Taskfile's `dotenv:` directive.
# Holds EXPECTED_ACCOUNT_ID and any other operator-specific values. The
# repo-root .gitignore also covers .env, but pin it here for clarity.
.env
.env.local

# Terraform working dirs and local scratch
**/.terraform/
**/.terraform-build/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
tmp/
