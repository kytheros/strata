# Operator-only — copy to .env (gitignored) and fill in your values.
#
# The Taskfile loads this file via the top-level `dotenv:` directive, so
# any variable set here is available as {{.NAME}} in tasks (and as $NAME
# in shell command bodies).

# Your 12-digit AWS account ID. The `preflight` task hard-fails if this
# is unset, and aborts if `aws sts get-caller-identity` returns a different
# account. Required for every dev:* task.
EXPECTED_ACCOUNT_ID=<ACCOUNT_ID>
