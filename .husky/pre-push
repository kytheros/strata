#!/usr/bin/env sh
# Pre-push gate — runs the deterministic CI checks locally so a long red
# push (like 2026-05-09's 105-commit catastrophe) can't ship again.
#
# Two-layer model:
#   1. Lightweight gate (always runs):
#        npm test, gitleaks (full history), npm audit --audit-level=high.
#      Catches test regressions, secret leaks, and HIGH-severity vulns.
#      ~75s on Windows.
#
#   2. Heavy gate (runs when about-to-push commit count > 5):
#        Semgrep + TFLint + Checkov via pinned Docker images that match CI.
#      Catches the slow-drift class of failure (false-positive regressions
#      in custom Semgrep rules, TFLint warnings on new modules, Checkov
#      policy violations). +~100s with warm Docker caches.
#
# The threshold is a pragmatic compromise: small day-to-day pushes stay
# fast, and the rare batched-up push pays the heavy cost it deserves.
#
# Run the heavy gate manually any time: `task pre-flight` from
# templates/aws/, or `./scripts/preflight-docker.sh` from repo root.
#
# Bypass everything: `git push --no-verify` (use sparingly).
set -e

echo "→ npm test"
npm test

echo "→ gitleaks (full history)"
gitleaks detect --source . --config .gitleaks.toml --no-banner

echo "→ npm audit (HIGH+)"
npm audit --audit-level=high

# Heavy gate: count commits being pushed; over the threshold runs Docker
# tools. `@{upstream}..HEAD` is the about-to-push range; if no upstream
# is set, count defaults to 0 and the gate is skipped (treat as a brand-
# new branch — push it and let CI gate it).
COUNT=$(git rev-list "@{upstream}..HEAD" --count 2>/dev/null || echo 0)
if [ "$COUNT" -gt 5 ]; then
  if [ -x "scripts/preflight-docker.sh" ]; then
    echo "→ heavy push ($COUNT commits) — running Docker-pinned gates"
    ./scripts/preflight-docker.sh
  else
    echo "→ scripts/preflight-docker.sh missing or not executable; skipping heavy gates" >&2
    echo "  (CI will catch any Semgrep/TFLint/Checkov drift on push)" >&2
  fi
else
  echo "→ light push ($COUNT commits ≤ 5) — skipping heavy Docker gate"
fi

echo "→ all pre-push gates passed"
