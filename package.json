{
  "name": "strata-mcp",
  "version": "2.2.1",
  "description": "Local memory layer for AI agents — coding assistants over MCP, game NPCs over REST",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Kytheros LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/kytheros/strata.git"
  },
  "homepage": "https://strata.kytheros.dev",
  "bugs": {
    "url": "https://github.com/kytheros/strata/issues"
  },
  "keywords": [
    "mcp",
    "strata",
    "search",
    "knowledge",
    "memory",
    "agents",
    "claude-code",
    "codex",
    "aider",
    "model-context-protocol",
    "rest-api",
    "game-engine",
    "npc",
    "unity"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js",
    "./d1": "./dist/storage/d1/index.js",
    "./pg": "./dist/storage/pg/index.js",
    "./storage/pg": "./dist/storage/pg/index.js",
    "./storage/interfaces": "./dist/storage/interfaces/index.js",
    "./storage/sqlite": "./dist/storage/sqlite/index.js",
    "./storage/factory": "./dist/storage/factory.js",
    "./tools/*": "./dist/tools/*.js",
    "./storage/*": "./dist/storage/*.js",
    "./indexing/*": "./dist/indexing/*.js",
    "./search/*": "./dist/search/*.js",
    "./knowledge/*": "./dist/knowledge/*.js",
    "./parsers/*": "./dist/parsers/*.js",
    "./utils/*": "./dist/utils/*.js",
    "./config": "./dist/config.js",
    "./watcher/*": "./dist/watcher/*.js",
    "./extensions/*": "./dist/extensions/*.js",
    "./extensions/embeddings/*": "./dist/extensions/embeddings/*.js",
    "./extensions/vector-search/*": "./dist/extensions/vector-search/*.js",
    "./ee/*": "./dist/ee/*.js",
    "./transports/*": "./dist/transports/*.js"
  },
  "bin": {
    "strata": "dist/cli.js",
    "strata-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:local-inference": "tsx evals/local-inference-quality/run-eval.ts",
    "eval:community-recall-tir-qdp": "tsx evals/community-recall-tir-qdp/eval.ts",
    "prepublishOnly": "npm run build && npm test",
    "build-index": "tsx src/cli/build-index.ts",
    "install-hook": "tsx src/cli/install.ts",
    "security:scan": "docker run --rm -v \"${PWD}:/src\" returntocorp/semgrep semgrep --config /src/.semgrep/custom-rules.yml --config p/typescript /src",
    "security:secrets": "gitleaks detect --source . --verbose --no-banner",
    "security:audit": "npm audit --omit=dev --audit-level=moderate",
    "benchmark": "tsx benchmarks/retrieval-benchmark.ts",
    "benchmark:full": "tsx benchmarks/retrieval-benchmark.ts && tsx benchmarks/mem0-benchmark.ts",
    "benchmark:longmemeval:download": "tsx benchmarks/longmemeval/download-dataset.ts",
    "benchmark:longmemeval": "tsx benchmarks/longmemeval/run-benchmark.ts",
    "benchmark:longmemeval:retrieval": "tsx benchmarks/longmemeval/run-benchmark.ts --retrieval-only",
    "benchmark:longmemeval:calibrate": "tsx benchmarks/longmemeval/run-calibration.ts",
    "autoresearch:longmemeval": "tsx autoresearch/longmemeval/run-eval.ts",
    "benchmark:tirqdp-baseline": "tsx benchmarks/longmemeval-tirqdp-baseline.ts",
    "rebuild:native": "npm rebuild --ignore-scripts=false better-sqlite3 esbuild sharp onnxruntime-node protobufjs workerd",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.0.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240806.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "aws-sdk-client-mock": "^4.1.0",
    "husky": "^9.1.0",
    "miniflare": "^4.20260317.1",
    "pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "^5.4.20"
  }
}
